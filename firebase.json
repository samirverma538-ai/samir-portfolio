{
  "functions": {
    "source": "backend",
    "runtime": "python311"
  },
  "hosting": {
    "public": "frontend",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api_backend"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
